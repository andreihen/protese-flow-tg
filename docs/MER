@startuml
' --- CONFIGURAÇÃO VISUAL ---
skinparam linetype ortho
skinparam shadowing false
skinparam packageStyle rectangle

' --- ENTIDADES (Tabelas) ---

entity "Usuario (CustomUser)" as User {
  *id : INT <<PK>>
  --
  *username : VARCHAR
  *email : VARCHAR
  *password : HASH
  *tipo_usuario : ENUM (Dentista, Gestor, Cadista)
  data_cadastro : DATETIME
}

entity "Pedido (Lab_Order)" as Pedido {
  *id : INT <<PK>>
  --
  *id_dentista : INT <<FK>>
  *nome_paciente : VARCHAR
  *tipo_servico : VARCHAR (Ex: Coroa, Faceta)
  dentes_selecionados : JSON (Ex: [11, 12, 21])
  cor_escala : VARCHAR (Ex: A2, BL3)
  *status : ENUM (Pendente, Em Produção, Concluído)
  data_criacao : DATETIME
  data_entrega_prevista : DATETIME
}

entity "Anexo (Order_Attachment)" as Anexo {
  *id : INT <<PK>>
  --
  *id_pedido : INT <<FK>>
  *caminho_arquivo : VARCHAR (Link do Arquivo)
  *tipo_arquivo : VARCHAR (STL, PLY, OBJ)
  tamanho_mb : FLOAT
  data_upload : DATETIME
}

entity "Historico_Status" as Historico {
  *id : INT <<PK>>
  --
  *id_pedido : INT <<FK>>
  *status_novo : VARCHAR
  *data_mudanca : DATETIME
  observacao : TEXT
}

' --- RELACIONAMENTOS ---

' Um Usuário (Dentista) pode fazer MUITOS Pedidos
User ||..o{ Pedido : "1:N (Solicita)"

' Um Pedido pode ter MUITOS Anexos (Ex: Arcada Sup + Inf)
Pedido ||..|{ Anexo : "1:N (Contém)"

' Um Pedido tem um histórico de mudanças
Pedido ||..o{ Historico : "1:N (Rastreia)"
@enduml
